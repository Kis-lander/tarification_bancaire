          <span class="h-1 w-1 rounded-full bg-stone-400"></span>
          <span>Publication officielle</span>
          <span class="h-1 w-1 rounded-full bg-stone-400"></span>
          <span>Portail de référence</span>
        </div>
      </div>

      <div class="relative">
