          <div class="relative overflow-hidden rounded-[1.75rem]">
            <img src="/images/bank.png" alt="Illustration BCC" class="h-[440px] w-full object-cover" />

            <div class="absolute inset-0 bg-gradient-to-t from-[#0A1931]/18 via-transparent to-white/10"></div>

            <div class="absolute left-4 top-5 rounded-2xl bg-white/95 px-4 py-3 shadow-lg shadow-stone-300/40">
              <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-accent-500">Statut public</p>
              <p class="mt-1 text-sm font-semibold text-state-navy">Tarifs homologues</p>
            </div>

            
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-10 grid gap-6 lg:grid-cols-3">
    <article class="rounded-3xl bg-blue-50 p-6 shadow-sm ring-1 ring-institution-800/10">
