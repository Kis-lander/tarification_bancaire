@layout('layouts/main')

  <section class="overflow-hidden rounded-[2.25rem] border border-stone-200/80 bg-gradient-to-br from-stone-50 via-[#f7f1e8] to-white shadow-institution">
    <div class="grid gap-12 px-6 py-12 md:px-10 xl:grid-cols-[1fr_0.95fr] lg:px-12 lg:py-16">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-accent-500">Institution financière publique</p>
