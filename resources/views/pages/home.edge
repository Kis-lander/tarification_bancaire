        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/compare"
            class="rounded-xl bg-state-navy px-6 py-3 text-center text-sm font-bold text-blue-900 shadow-md shadow-stone-700/50 transition hover:bg-institution-800"
